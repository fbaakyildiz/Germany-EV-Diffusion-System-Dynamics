{UTF-8}
adoption rate=
	infectivity*contacts*not pot EV customer frac*EV Word of Mouth
	~	
	~		|

percentage of fast chargers=
	number of fast charging stations/number of charging stations
	~	
	~		|

desired percentage of fast chargers=
	0.2
	~	
	~		|

new charging stations=
	MAX( 0, deviation/(planning and construction time/2))
	~	
	~		|

avg charging time=
	(percentage of fast chargers*charging time fast chargers + (1-percentage of fast chargers\
		) *charging time normal chargers)
	~	hour
	~		|

normalized time EV=
	(avg noticed charging time EV-threshold charging time)/threshold charging time
	~	
	~		|

not pot EV customer frac=
	1-Potential EV Customer percentage-people against EV
	~	
	~		|

perception update operating cost EV=
	1/perception delay operating cost EV *(operating cost per km EV - perceived operating cost per km EV\
		)
	~	
	~		|

people against EV=
	0.05
	~	
	~		|

avg noticed charging time EV=
	(avg charging time+avg waiting time)*(1-charging integrated in daily life)
	~	hour
	~		|

avg operating cost=
	(operating cost per km CV + perceived operating cost per km EV)/2
	~	euro/km
	~		|

number of fast charging stations planned= INTEG (
	new fast charging stations-fast charging station construction,
		0)
	~	
	~		|

percentage of fast chargers in planning=
	number of fast charging stations planned/number of stations planned
	~	
	~		|

EV Word of Mouth=
	EV share of total*100
	~	
	~		|

new fast charging stations=
	new charging stations*desired percentage of fast chargers
	~	
	~		|

EV operating cost normalized=
	(perceived operating cost per km EV - avg operating cost)/avg operating cost
	~	
	~		|

time utility of CV=
	1
	~	
	~		|

fast chargers retired=
	old stations retired*percentage of fast chargers
	~	
	~		|

fast charging station construction=
	charging station construction*percentage of fast chargers in planning
	~	
	~		|

charging integrated in daily life=
	0.4
	~	
	~		|

Potential EV Customer percentage= INTEG (
	potential EV customer increase,
		0.1)
	~	
	~		|

total car sales=
	EV retirement+CV retirement
	~	
	~		|

number of fast charging stations= INTEG (
	fast charging station construction-fast chargers retired,
		100)
	~	
	~		|

perceived operating cost per km EV= INTEG (
	perception update operating cost EV,
		operating cost per km EV)
	~	
	~		|

perception delay operating cost EV=
	3
	~	
	~		|

threshold charging time=
	0.5
	~	
	~		|

planning and construction time=
	1
	~	
	~		|

charging station construction=
	number of stations planned/(planning and construction time/2)
	~	
	~		|

initial electricity consumption=
	0.2
	~	
	~		|

perceived number of EV= INTEG (
	perception update EV,
		total number of EVs)
	~	
	~		|

EV share of total=
	total number of EVs/total cars
	~	
	~		|

CV sales=
	total car sales*real CV market share
	~	
	~		|

learning rate exponent electricity consumption=
	LOG( 1-learning rate electricity consumption, 10)/LOG( 2 , 10)
	~	
	~		|

potential EV customer increase=
	adoption rate
	~	
	~		|

electricity consumption=
	initial electricity consumption*(cumulative production/ initial production)^learning rate exponent electricity consumption
	~	kWh/km
	~		|

infectivity=
	0.1
	~	
	~		|

contacts=
	10
	~	
	~		|

real CV market share=
	1-real EV market share
	~	
	~		|

Avg Range of new EV=
	initial avg range*(cumulative production/initial production)^-learning rate exponent EV range
	~	
	~		|

EV sales=
	total car sales*real EV market share
	~	
	~		|

perception update EV=
	1/perc delay number EV * (total number of EVs-perceived number of EV)
	~	
	~		|

real EV market share=
	ideal EV market share*Potential EV Customer percentage
	~	
	~		|

weight of time utility=
	-0.25
	~	
	~		|

perceived avg EV range= INTEG (
	perc update EV range,
		Avg Range EV1)
	~	
	~		|

learning rate electricity consumption=
	0.03
	~	
	~		|

Avg Range EV1=
	Total Range EV1/EV1
	~	
	~		|

outdated1=
	ageing1*Avg Range EV1
	~	
	~		|

time utility of EV=
	EXP(normalized time EV*weight of time utility)
	~	
	~		|

perc update EV range=
	(Avg Range EV1-perceived avg EV range)/perc delay EV range
	~	
	~		|

utility of EV=
	operating cost utility EV * price utility of EV * range utility of EV *time utility of EV
	~	
	~		|

utility of CV=
	operating cost utiilty CV * price utility of CV * range utility of CV *time utility of CV
	~	
	~		|

CV initial=
	4.39e+07
	~	
	~		|

ideal CV market share=
	utility of CV/total utility
	~	
	~		|

CV operating cost normalized=
	(operating cost per km CV - avg operating cost)/avg operating cost
	~	
	~		|

CV price normalized=
	(CV Price - Avg vehicle price)/Avg vehicle price
	~	
	~		|

CV range normalized=
	(avg CV range - avg range)/avg range
	~	
	~		|

avg CV range=
	500
	~	
	~		|

avg EV price=
	initial avg price*(cumulative production/ initial production)^learning rate exp Ev price\
		 - government subsidies on EV price
	~	
	~		|

Avg vehicle price=
	(CV Price+perceived avg EV price)/2
	~	
	~		|

avg range=
	(avg CV range + perceived avg EV range)/2
	~	
	~		|

ideal EV market share=
	utility of EV/total utility
	~	
	~		|

operating cost per km CV=
	fuel price*fuel consumption
	~	euro/km
	~		|

operating cost per km EV=
	electricity price*electricity consumption
	~	euro/km
	~		|

avg waiting time = WITH LOOKUP (
	perceived chargers per EV,
		          ([(0,0)-(0.2,10)],(0,20),(0.00144509,15.3226),(0.00289017,10.8065),(0.00722543\
		,7.25806),(0.0144509,4.67742),(0.0202312,3.22581),(0.0364162,1.53226),(0.0433526,0.927419\
		),(0.05,0.5),(0.0566474,0.282258),(0.0682081,0.120968),(0.083237,0.0806452),(0.1,0)\
		,(0.5,0) ))
	~	hour
	~		|

operating cost utility EV=
	EXP(EV operating cost normalized * weight of operating cost utility)
	~	
	~		|

chargers per EV=
	perceived number of chargers/perceived number of EV
	~	
	~		|

