	33000
	~	
	~		|

perceived number of chargers= INTEG (
	perc update number of chargers,
		number of chargers)
	~	
	~		|

electricity price=
	0.25
	~	euro/kWh
	~		|

number of chargers=
	number of charging stations + number of stations planned
	~	
	~		|

total utility=
	utility of CV + utility of EV
	~	
	~		|

desired number of chargers=
	desired chargers per EV * perceived number of EV
	~	
	~		|

deviation=
	desired number of chargers - perceived number of chargers
	~	
	~		|

EV range normalized=
	(perceived avg EV range - avg range)/avg range
	~	
